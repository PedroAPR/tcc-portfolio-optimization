   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 9 — Inferência Econométrica de Desempenho e Caracterização do Benchmark\n",
    "\n",
    "**TCC — Pedro Augusto Pinheiro Reis · Ciências Contábeis · UFG**\n",
    "\n",
    "Este notebook operacionaliza a caracterização econométrica do benchmark (IBOVESPA) e executa os testes de hipóteses estatísticas comparando as carteiras ótimas contra o mercado."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Importações e Configurações"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-03T21:01:20.909567Z",
     "iopub.status.busy": "2026-06-03T21:01:20.909567Z",
     "iopub.status.idle": "2026-06-03T21:01:22.622904Z",
     "shell.execute_reply": "2026-06-03T21:01:22.622904Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ Configurações carregadas. Total de estratégias: 16 | benchmark: EqualWeight\n",
      "  Inclui EqualWeight_BuyHold (1/N sem rebalanceamento) para análise de concentração.\n"
     ]
    }
   ],
   "source": [
    "import sys\n",
    "import warnings\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from scipy import stats\n",
    "import statsmodels.api as sm\n",
    "from statsmodels.tsa.stattools import adfuller, kpss\n",
    "from statsmodels.stats.diagnostic import het_arch\n",
    "from arch import arch_model\n",
    "from arch.unitroot import VarianceRatio\n",
    "\n",
    "from utils.config_loader import carregar_parametros\n",
    "from utils.inferencia import (\n",
    "    fmt_pvalor,\n",
    "    sharpe,\n",
    "    sortino,\n",
    "    sharpe_de_excesso,\n",
    "    sortino_de_excesso,\n",
    "    cagr,\n",
    "    max_drawdown,\n",
    "    _wald_spanning,\n",
    "    _jk_memmel,\n",
    "    bootstrap_ic,\n",
    "    diagnostico_residuos,\n",
    "    diagnosticos_serie,\n",
    "    lw_bootstrap_sharpe,\n",
    "    lw_bootstrap_sortino,\n",
    "    TRADING_DAYS\n",
    ")\n",
    "from statsmodels.stats.multitest import multipletests\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "cfg = carregar_parametros()\n",
    "SEED = cfg.get(\"SEED\", 42)\n",
    "BOOTSTRAP_REPS = cfg.get(\"BOOTSTRAP_REPS\", 2000)\n",
    "BOOTSTRAP_BLOCK_MEAN = cfg.get(\"BOOTSTRAP_BLOCK_MEAN\", 21)\n",
    "SPANNING_MAX_LAGS = cfg.get(\"SPANNING_MAX_LAGS\", 5)\n",
    "\n",
    "project_root = Path.cwd().parent.parent\n",
    "INPUT_DIR_IBOV     = project_root / \"data\" / \"Ibov\" / \"Ibov_Diario\"\n",
    "INPUT_DIR_CDI      = project_root / \"data\" / \"CDI\"\n",
    "INPUT_DIR_STRATEGY = project_root / \"data\" / \"Estrategias\"\n",
    "OUTPUT_DIR         = project_root / \"data\" / \"Estrategias\"\n",
    "OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "ESTRATEGIAS = [\n",
    "    \"EqualWeight\", \"EqualWeight_BuyHold\", \"InvVol\",\n",
    "    \"MinVar\", \"MinVar_c10\", \"MaxSharpe\", \"MaxSharpe_c10\",\n",
    "    \"MaxOmega\", \"MaxSortino\", \"MaxKappa3\", \"MinCVaR\", \"MinCDaR\",\n",
    "    \"BL_classico\", \"BL_classico_c10\", \"BL_downside\", \"BL_downside_c10\"\n",
    "]\n",
    "\n",
    "BENCHMARK  = \"EqualWeight\"   # DeMiguel et al. (2009) — desafiante canônico 1/N\n",
    "ALPHA_SIG  = 0.05\n",
    "BOOT_BLOCO = 10              # bloco esperado do bootstrap estacionário (pregões)\n",
    "BOOT_REPS  = 2000            # reamostragens\n",
    "\n",
    "print(f\"✓ Configurações carregadas. Total de estratégias: {len(ESTRATEGIAS)} | benchmark: {BENCHMARK}\")\n",
    "print(f\"  Inclui EqualWeight_BuyHold (1/N sem rebalanceamento) para análise de concentração.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Ingestão de Dados e Alinhamento do Benchmark"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-03T21:01:22.656464Z",
     "iopub.status.busy": "2026-06-03T21:01:22.654938Z",
     "iopub.status.idle": "2026-06-03T21:01:22.682040Z",
     "shell.execute_reply": "2026-06-03T21:01:22.681524Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✓ Benchmark carregado e alinhado: 3,966 observações.\n"
     ]
    }
   ],
   "source": [
    "ibov_path = INPUT_DIR_IBOV / \"ibov_diario_2010_2026.csv\"\n",
    "if not ibov_path.exists():\n",
    "    raise FileNotFoundError(\"ibov_diario_2010_2026.csv não encontrado.\")\n",
    "ibov = pd.read_csv(ibov_path, parse_dates=[\"data\"])\n",
    "ibov = ibov.dropna(subset=[\"ibov_ret_simples\"]).reset_index(drop=True)\n",
    "\n",
    "cdi_path = INPUT_DIR_CDI / \"cdi_diario_bcb_2010_atual.csv\"\n",
    "if not cdi_path.exists():\n",
    "    raise FileNotFoundError(\"cdi_diario_bcb_2010_atual.csv não encontrado.\")\n",
    "cdi_df = pd.read_csv(cdi_path, sep=\";\", parse_dates=[\"data\"])\n",
    "\n",
    "cdi_serie = cdi_df.set_index(\"data\")[\"cdi_diario\"].reindex(ibov[\"data\"]).ffill().bfill()\n",
    "ibov[\"cdi_diario\"] = cdi_serie.values\n",
    "ibov[\"ibov_ret_log\"] = np.log(1 + ibov[\"ibov_ret_simples\"])\n",
    "\n",
    "print(f\"✓ Benchmark carregado e alinhado: {len(ibov):,} observações.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Testes de Raiz Unitária e Ordem de Integração do IBOV"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-03T21:01:22.683569Z",
     "iopub.status.busy": "2026-06-03T21:01:22.683569Z",
     "iopub.status.idle": "2026-06-03T21:01:22.915266Z",
     "shell.execute_reply": "2026-06-03T21:01:22.914740Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "========================================================================\n",
      "TESTES DE ESTACIONARIEDADE DO BENCHMARK (IBOV)\n",
      "========================================================================\n",
      "\n",
      "ADF em log-retornos:   estat=-23.3832 | p-valor=< 0,001 ***\n",
      "KPSS em log-retornos:  estat=0.1492 | p-valor=0.1000\n",
      "ADF em nível (close):  estat=-0.0549 | p-valor=0.9537\n",
      "KPSS em nível (close): estat=8.5742 | p-valor=0.0100 **\n"
     ]
    }
   ],
   "source": [
    "r = ibov[\"ibov_ret_log\"].dropna()\n",
    "p = ibov[\"ibov_close\"]\n",
    "\n",
    "adf_r = adfuller(r, autolag=\"AIC\")\n",
    "adf_p = adfuller(p, autolag=\"AIC\")\n",
    "kpss_r = kpss(r, regression=\"c\", nlags=\"auto\")\n",
    "kpss_p = kpss(p, regression=\"c\", nlags=\"auto\")\n",
    "\n",
    "print(\"========================================================================\")\n",
    "print(\"TESTES DE ESTACIONARIEDADE DO BENCHMARK (IBOV)\")\n",
    "print(\"========================================================================\\n\")\n",
    "print(f\"ADF em log-retornos:   estat={adf_r[0]:.4f} | p-valor={fmt_pvalor(adf_r[1])}\")\n",
    "print(f\"KPSS em log-retornos:  estat={kpss_r[0]:.4f} | p-valor={fmt_pvalor(kpss_r[1])}\")\n",
    "print(f\"ADF em nível (close):  estat={adf_p[0]:.4f} | p-valor={fmt_pvalor(adf_p[1])}\")\n",
    "print(f\"KPSS em nível (close): estat={kpss_p[0]:.4f} | p-valor={fmt_pvalor(kpss_p[1])}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Diagnóstico de Momentos Superiores e Dependência Temporal"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-03T21:01:22.916783Z",
     "iopub.status.busy": "2026-06-03T21:01:22.916783Z",
     "iopub.status.idle": "2026-06-03T21:01:22.927589Z",
     "shell.execute_reply": "2026-06-03T21:01:22.927057Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "========================================================================\n",
      "DIAGNÓSTICO ESTATÍSTICO DE COMPORTAMENTO DISTRIBUTIVO (IBOV)\n",
      "========================================================================\n",
      "\n",
      "ARCH-LM (10 lags):  estat = 1514.10  p-valor = < 0,001 ***\n",
      "Jarque-Bera:        estat = 24534.08  p-valor = < 0,001 ***\n",
      "Assimetria:         -0.7859\n",
      "Curtose excedente:  +12.0997\n"
     ]
    }
   ],
   "source": [
    "arch_stat, arch_p, _, _ = het_arch(r, nlags=10)\n",
    "jb_stat, jb_p = stats.jarque_bera(r)\n",
    "\n",
    "print(\"========================================================================\")\n",
    "print(\"DIAGNÓSTICO ESTATÍSTICO DE COMPORTAMENTO DISTRIBUTIVO (IBOV)\")\n",
    "print(\"========================================================================\\n\")\n",
    "print(f\"ARCH-LM (10 lags):  estat = {arch_stat:.2f}  p-valor = {fmt_pvalor(arch_p)}\")\n",
    "print(f'Jarque-Bera:        estat = {jb_stat:.2f}  p-valor = {fmt_pvalor(jb_p)}')\n",
    "print(f\"Assimetria:         {r.skew():+.4f}\")\n",
    "print(f\"Curtose excedente:  {r.kurt():+.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Teste de Razão de Variâncias de Lo-MacKinlay"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-03T21:01:22.929129Z",
     "iopub.status.busy": "2026-06-03T21:01:22.929129Z",
     "iopub.status.idle": "2026-06-03T21:01:22.937294Z",
