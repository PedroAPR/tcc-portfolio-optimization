   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "========================================================================\n",
      "APÊNDICE L — INFERÊNCIA COMPARATIVA TRANSVERSAL (HAC Newey-West)\n",
      "========================================================================\n",
      "\n",
      "\n",
      "> EqualWeight\n",
      "   CAPM:     alfa = -4.69% a.a. | beta = 0.770 | t(NW) = -1.678 | p = 0.0933 *\n",
      "   JK/Memmel vs IBOV: z = -1.896 | p = 0.0579 *\n",
      "   Spanning (a=0,b=1): F = 26.49 | p = < 0,001 ***\n",
      "   Sharpe = -0.0754 | Sortino = -0.1025\n",
      "\n",
      "> EqualWeight_BuyHold\n",
      "   CAPM:     alfa = +4.06% a.a. | beta = 0.755 | t(NW) = +1.655 | p = 0.0980 *\n",
      "   JK/Memmel vs IBOV: z = +1.517 | p = 0.1293\n",
      "   Spanning (a=0,b=1): F = 26.62 | p = < 0,001 ***\n",
      "   Sharpe = +0.3724 | Sortino = +0.5195\n",
      "\n",
